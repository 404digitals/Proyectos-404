            <button class="modal-close" onclick="closeModal()">✕</button>
            <img class="modal-img" id="m-img" src="" alt="" />
            <div class="modal-content">
                <div class="modal-year" id="m-year"></div>
                <h2 class="modal-name" id="m-name"></h2>
                <p class="modal-cat" id="m-cat"></p>
                <p class="modal-bio" id="m-bio"></p>
                <a href="https://www.fmda.es" target="_blank" class="btn-outline" style="font-size:.6rem">Ver en fmda.es →</a>
            </div>
