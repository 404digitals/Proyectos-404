    <script>
        const nav = document.getElementById('mainNav');
        window.addEventListener('scroll', () => {
            nav.classList.toggle('scrolled', window.scrollY > 60);
            document.getElementById('btt').classList.toggle('visible', window.scrollY > 400);
        });

        function tick() {
            var target = new Date('2026-11-03T20:00:00').getTime();
            var now = new Date().getTime();
            var t = target - now;
            if (t < 0) t = 0;
            var d = Math.floor(t / (1000 * 60 * 60 * 24));
            var h = Math.floor((t % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            var m = Math.floor((t % (1000 * 60 * 60)) / (1000 * 60));
            var s = Math.floor((t % (1000 * 60)) / 1000);
            var ed = document.getElementById('cd-dias');
            var eh = document.getElementById('cd-horas');
            var em = document.getElementById('cd-min');
            var es = document.getElementById('cd-seg');
            if (ed) ed.textContent = String(d).padStart(3, '0');
            if (eh) eh.textContent = String(h).padStart(2, '0');
            if (em) em.textContent = String(m).padStart(2, '0');
            if (es) es.textContent = String(s).padStart(2, '0');
        }
        tick();
        setInterval(tick, 1000);

        function openModal(year, name, cat, bio, img) {
            document.getElementById('m-year').textContent = 'Premio Madrileño del Año · ' + year;
            document.getElementById('m-name').textContent = name;
            document.getElementById('m-cat').textContent = cat;
            document.getElementById('m-bio').textContent = bio;
            document.getElementById('m-img').src = img;
            document.getElementById('m-img').alt = name;
            document.getElementById('modal').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            document.getElementById('modal').classList.remove('active');
            document.body.style.overflow = '';
        }

        function closeOut(e) {
            if (e.target === document.getElementById('modal')) closeModal();
        }
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeModal();
        });
        const io = new IntersectionObserver(function(entries) {
            entries.forEach(function(e) {
                if (e.isIntersecting) {
                    e.target.style.opacity = '1';
                    e.target.style.transform = 'translateY(0)';
                }
            });
        }, {
            threshold: 0.08
        });
        document.querySelectorAll('.ganador-card,.noticia-card,.stat-item,.gala-detail,.medio-tag,.patro-badge,.medios-stat-box').forEach(function(el, i) {
            el.style.opacity = '0';
            el.style.transform = 'translateY(20px)';
            el.style.transition = 'opacity .6s ' + String(i * .05) + 's ease,transform .6s ' + String(i * .05) + 's ease';
            io.observe(el);
        });
    </script>
