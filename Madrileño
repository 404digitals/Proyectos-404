<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>Fundación Madrileño del Año — fmdã</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
         :root {
            --crimson: #8B1A1A;
            --crimson-light: #A52020;
            --crimson-dark: #5C0F0F;
            --gold: #C9A84C;
            --gold-light: #E8C97A;
            --black: #0A0A0A;
            --dark: #111;
            --dark2: #1A1A1A;
            --cream: #F5EFE0;
            --white: #FAFAF8;
            --muted: #888;
            --serif: 'Cormorant Garamond', Georgia, serif;
            --sans: 'Montserrat', sans-serif;
        }
        
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }
        
        html {
            scroll-behavior: smooth
        }
        
        body {
            background: var(--dark);
            color: var(--cream);
            font-family: var(--sans);
            font-weight: 300;
            overflow-x: hidden
        }
        
         ::-webkit-scrollbar {
            width: 4px
        }
        
         ::-webkit-scrollbar-track {
            background: var(--black)
        }
        
         ::-webkit-scrollbar-thumb {
            background: var(--crimson-dark);
            border-radius: 2px
        }
        
        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.2rem 4rem;
            transition: background .4s, padding .4s
        }
        
        nav.scrolled {
            background: rgba(10, 10, 10, .95);
            backdrop-filter: blur(16px);
            padding: .8rem 4rem;
            border-bottom: 1px solid rgba(139, 26, 26, .3)
        }
        
        .nav-logo {
            display: flex;
            align-items: center;
            line-height: 1
        }
        
        .nav-logo .logo-main {
            font-family: var(--serif);
            font-size: 1.1rem;
            font-weight: 600;
            letter-spacing: .06em;
            color: var(--gold-light)
        }
        
        .nav-logo .logo-sub {
            font-size: .5rem;
            font-weight: 500;
            letter-spacing: .35em;
            text-transform: uppercase;
            color: var(--muted);
            margin-top: 3px
        }
        
        .nav-links {
            display: flex;
            gap: 2rem;
            list-style: none
        }
        
        .nav-links a {
            font-size: .62rem;
            font-weight: 500;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: var(--cream);
            text-decoration: none;
            transition: color .3s;
            position: relative
        }
        
        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            right: 0;
            height: 1px;
            background: var(--crimson-light);
            transform: scaleX(0);
            transition: transform .3s;
            transform-origin: left
        }
        
        .nav-links a:hover {
            color: var(--gold-light)
        }
        
        .nav-links a:hover::after {
            transform: scaleX(1)
        }
        
        .nav-cta {
            font-size: .6rem;
            font-weight: 600;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: var(--white);
            background: var(--crimson);
            padding: .55rem 1.4rem;
            text-decoration: none;
            transition: background .3s
        }
        
        .nav-cta:hover {
            background: var(--crimson-light)
        }
        
        #inicio {
            position: relative;
            height: 100vh;
            min-height: 700px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            overflow: hidden
        }
        
        .hero-bg {
            position: absolute;
            inset: 0;
            background-image: url('data:image/jpeg;base64,');
            background-size: cover;
            background-position: center;
            filter: brightness(.22) saturate(.7);
            transform: scale(1.05);
            animation: heroZoom 20s ease-in-out infinite alternate
        }
        
        @keyframes heroZoom {
            from {
                transform: scale(1.05)
            }
            to {
                transform: scale(1.12)
            }
        }
        
        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(10, 10, 10, .2) 0%, rgba(10, 10, 10, .5) 55%, rgba(10, 10, 10, 1) 100%)
        }
        
        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 900px;
            padding: 0 2rem;
            animation: fadeUp 1.4s ease forwards;
            opacity: 0;
            transform: translateY(30px)
        }
        
        @keyframes fadeUp {
            to {
                opacity: 1;
                transform: translateY(0)
            }
        }
        
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: .8rem;
            font-size: .58rem;
            font-weight: 600;
            letter-spacing: .4em;
            text-transform: uppercase;
            color: var(--gold);
            border: 1px solid rgba(201, 168, 76, .35);
            padding: .4rem 1.2rem;
            margin-bottom: 2rem
        }
        
        .hero-badge::before,
        .hero-badge::after {
            content: '';
            width: 16px;
            height: 1px;
            background: var(--gold)
        }
        
        .hero-title {
            font-family: var(--serif);
            font-size: clamp(3rem, 8vw, 6.5rem);
            font-weight: 300;
            line-height: 1;
            color: var(--white);
            letter-spacing: -.01em;
            margin-bottom: .3rem
        }
        
        .hero-title em {
            font-style: italic;
            color: var(--gold-light)
        }
        
        .hero-sub {
            font-family: var(--serif);
            font-size: clamp(1.2rem, 2.5vw, 1.9rem);
            font-weight: 300;
            font-style: italic;
            color: rgba(245, 239, 224, .6);
            margin-bottom: 2rem
        }
        
        .hero-divider {
            width: 60px;
            height: 1px;
            background: linear-gradient(to right, transparent, var(--crimson-light), transparent);
            margin: 4px auto 2rem
        }
        
        .hero-org {
            font-size: .62rem;
            font-weight: 400;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: rgba(245, 239, 224, .4);
            margin-bottom: .6rem
        }
        
        .hero-org span {
            color: var(--gold)
        }
        
        .hero-triangle {
            font-size: .65rem;
            font-weight: 500;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: rgba(245, 239, 224, .45);
            margin-bottom: 2.5rem
        }
        
        .hero-triangle span {
            color: var(--gold)
        }
        
        .hero-btns {
            display: flex;
            gap: 1.2rem;
            justify-content: center;
            flex-wrap: wrap
        }
        
        .btn-primary {
            font-family: var(--sans);
            font-size: .62rem;
            font-weight: 600;
            letter-spacing: .25em;
            text-transform: uppercase;
            color: var(--white);
            background: var(--crimson);
            padding: .9rem 2.2rem;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: background .3s, transform .2s;
            display: inline-block
        }
        
        .btn-primary:hover {
            background: var(--crimson-light);
            transform: translateY(-1px)
        }
        
        .btn-outline {
            font-family: var(--sans);
            font-size: .62rem;
            font-weight: 500;
            letter-spacing: .25em;
            text-transform: uppercase;
            color: var(--gold-light);
            background: transparent;
            padding: .9rem 2.2rem;
            text-decoration: none;
            border: 1px solid rgba(201, 168, 76, .4);
            cursor: pointer;
            transition: border-color .3s, color .3s;
            display: inline-block
        }
        
        .btn-outline:hover {
            border-color: var(--gold-light);
            color: var(--white)
        }
        
        .hero-scroll {
            position: absolute;
            bottom: 2.5rem;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: .5rem;
            z-index: 2
        }
        
        .hero-scroll span {
            font-size: .5rem;
            letter-spacing: .3em;
            text-transform: uppercase;
            color: var(--muted)
        }
        
        .scroll-line {
            width: 1px;
            height: 40px;
            background: linear-gradient(to bottom, var(--crimson-light), transparent);
            animation: scrollLine 2s infinite
        }
        
        @keyframes scrollLine {
            0% {
                opacity: 0;
                transform: scaleY(0);
                transform-origin: top
            }
            50% {
                opacity: 1;
                transform: scaleY(1)
            }
            100% {
                opacity: 0;
                transform: scaleY(1);
                transform-origin: bottom
            }
        }
        
        section {
            padding: 8rem 0
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 4rem
        }
        
        .section-label {
            font-size: .58rem;
            font-weight: 600;
            letter-spacing: .4em;
            text-transform: uppercase;
            color: var(--crimson-light);
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.5rem
        }
        
        .section-label::before {
            content: '';
            width: 30px;
            height: 1px;
            background: var(--crimson-light)
        }
        
        .section-title {
            font-family: var(--serif);
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 300;
            line-height: 1.1;
            color: var(--white);
            margin-bottom: 1.5rem
        }
        
        .section-title em {
            font-style: italic;
            color: var(--gold-light)
        }
        
        .crimson-line {
            width: 80px;
            height: 2px;
            background: linear-gradient(to right, var(--crimson-dark), var(--crimson-light), var(--crimson-dark));
            margin-bottom: 3rem
        }
        /* SOBRE */
        
        #sobre {
            background: var(--black);
            position: relative
        }
        
        #sobre::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(to right, transparent, var(--crimson-dark), transparent)
        }
        
        .sobre-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6rem;
            align-items: center
        }
        
        .sobre-text p {
            font-family: var(--serif);
            font-size: 1.2rem;
            line-height: 1.9;
            color: rgba(245, 239, 224, .75);
            margin-bottom: 1.5rem
        }
        
        .sobre-text p:first-of-type {
            font-size: 1.45rem;
            color: var(--cream);
            font-weight: 300
        }
        
        .sobre-img-wrap {
            position: relative
        }
        
        .sobre-img-wrap img {
            width: 100%;
            object-fit: cover;
            display: block
        }
        
        .sobre-img-wrap::before {
            content: '';
            position: absolute;
            top: -16px;
            left: -16px;
            right: 16px;
            bottom: 16px;
            border: 1px solid rgba(139, 26, 26, .35);
            z-index: -1
        }
        
        .sobre-img-wrap::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(10, 10, 10, .5) 0%, transparent 50%);
            pointer-events: none
        }
        
        .stats-row {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 0;
            margin-top: 4rem;
            border-top: 1px solid rgba(139, 26, 26, .25);
            border-bottom: 1px solid rgba(139, 26, 26, .25)
        }
        
        .stat-item {
            padding: 2.2rem 1.5rem;
            text-align: center;
            border-right: 1px solid rgba(139, 26, 26, .25)
        }
        
        .stat-item:last-child {
            border-right: none
        }
        
        .stat-number {
            font-family: var(--serif);
            font-size: 3rem;
            font-weight: 300;
            color: var(--gold-light);
            line-height: 1;
            display: block
        }
        
        .stat-label {
            font-size: .55rem;
            font-weight: 500;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: var(--muted);
            margin-top: .6rem;
            display: block
        }
        /* EL GALARDÓN */
        
        #galardon {
            background: var(--dark2);
            position: relative
        }
        
        #galardon::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(to right, transparent, var(--crimson-dark), transparent)
        }
        
        .galardon-grid {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 6rem;
            align-items: center
        }
        
        .trophy-wrap {
            position: relative;
            text-align: center
        }
        
        .trophy-wrap img {
            width: 100%;
            max-width: 340px;
            object-fit: contain;
            display: block;
            margin: 0 auto;
            filter: drop-shadow(0 20px 60px rgba(0, 0, 0, .6))
        }
        
        .trophy-caption {
            margin-top: 2rem;
            font-size: .6rem;
            font-weight: 500;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: var(--muted)
        }
        
        .galardon-text p {
            font-family: var(--serif);
            font-size: 1.2rem;
            line-height: 1.9;
            color: rgba(245, 239, 224, .75);
            margin-bottom: 1.5rem
        }
        
        .galardon-text p:first-of-type {
            font-size: 1.5rem;
            color: var(--cream)
        }
        
        .director-card {
            background: rgba(139, 26, 26, .08);
            border: 1px solid rgba(139, 26, 26, .25);
            padding: 2rem;
            margin-top: 2.5rem;
            display: flex;
            align-items: center;
            gap: 2rem
        }
        
        .director-card .icon {
            width: 48px;
            height: 48px;
            border: 1px solid rgba(201, 168, 76, .3);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--gold);
            font-size: 1.2rem;
            flex-shrink: 0
        }
        
        .director-card .info strong {
            display: block;
            font-family: var(--serif);
            font-size: 1.15rem;
            color: var(--white);
            margin-bottom: .2rem
        }
        
        .director-card .info span {
            font-size: .62rem;
            letter-spacing: .1em;
            color: var(--muted)
        }
        
        .director-card .info a {
            display: block;
            font-size: .68rem;
            color: var(--crimson-light);
            text-decoration: none;
            margin-top: .3rem;
            letter-spacing: .05em
        }
        
        .director-card .info a:hover {
            color: var(--gold-light)
        }
        /* GANADORES */
        
        #ganadores {
            background: var(--dark)
        }
        
        .ganadores-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 4rem
        }
        
        .ganadores-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.2rem
        }
        
        .ganador-card {
            position: relative;
            overflow: hidden;
            cursor: pointer
        }
        
        .ganador-card:first-child {
            grid-column: span 2;
            grid-row: span 2
        }
        
        .ganador-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: top center;
            aspect-ratio: 3/4;
            filter: brightness(.85);
            transition: transform .7s ease, filter .5s ease;
            display: block
        }
        
        .ganador-card:first-child img {
            aspect-ratio: auto;
            min-height: 520px
        }
        
        .ganador-card:hover img {
            transform: scale(1.05);
            filter: brightness(.95)
        }
        
        .ganador-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0, 0, 0, .92) 0%, rgba(0, 0, 0, .3) 55%, transparent 100%);
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 1.8rem
        }
        
        .ganador-card:first-child .ganador-overlay {
            padding: 2.5rem
        }
        
        .ganador-year {
            font-size: .55rem;
            font-weight: 600;
            letter-spacing: .35em;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: .5rem
        }
        
        .ganador-name {
            font-family: var(--serif);
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--white);
            line-height: 1.1;
            margin-bottom: .3rem
        }
        
        .ganador-card:first-child .ganador-name {
            font-size: 2rem
        }
        
        .ganador-desc {
            font-size: .65rem;
            color: rgba(245, 239, 224, .65);
            line-height: 1.5
        }
        
        .ganador-badge {
            position: absolute;
            top: 1.2rem;
            right: 1.2rem;
            background: var(--crimson);
            color: var(--white);
            font-size: .52rem;
            font-weight: 700;
            letter-spacing: .12em;
            padding: .35rem .8rem;
            text-transform: uppercase
        }
        
        .ganador-ribbon {
            position: absolute;
            top: 1.2rem;
            left: 1.2rem;
            background: rgba(0, 0, 0, .65);
            backdrop-filter: blur(4px);
            color: var(--gold-light);
            font-size: .52rem;
            font-weight: 600;
            letter-spacing: .15em;
            padding: .3rem .7rem;
            text-transform: uppercase;
            border: 1px solid rgba(201, 168, 76, .3)
        }
        
        .quote-block {
            background: var(--crimson-dark);
            border-left: 4px solid var(--gold);
            padding: 2.5rem 3rem;
            margin: 4rem 0 0;
            position: relative
        }
        
        .quote-block::before {
            content: '"';
            font-family: var(--serif);
            font-size: 6rem;
            color: rgba(201, 168, 76, .2);
            position: absolute;
            top: -1rem;
            left: 2rem;
            line-height: 1
        }
        
        .quote-text {
            font-family: var(--serif);
            font-size: 1.5rem;
            font-weight: 300;
            font-style: italic;
            color: var(--white);
            line-height: 1.6;
            margin-bottom: 1rem
        }
        
        .quote-author {
            font-size: .62rem;
            font-weight: 600;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: var(--gold)
        }
        /* REVISTA */
        
        #revista {
            background: var(--black);
            position: relative
        }
        
        #revista::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(to right, transparent, var(--crimson-dark), transparent)
        }
        
        .revista-grid {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 6rem;
            align-items: center
        }
        
        .revista-cover {
            position: relative
        }
        
        .revista-cover img {
            width: 100%;
            display: block;
            box-shadow: 0 30px 80px rgba(0, 0, 0, .6)
        }
        
        .revista-cover::before {
            content: '';
            position: absolute;
            top: -12px;
            left: -12px;
            right: 12px;
            bottom: 12px;
            border: 1px solid rgba(201, 168, 76, .2);
            z-index: -1
        }
        
        .revista-text p {
            font-family: var(--serif);
            font-size: 1.2rem;
            line-height: 1.9;
            color: rgba(245, 239, 224, .75);
            margin-bottom: 1.5rem
        }
        
        .revista-text p:first-of-type {
            font-size: 1.45rem;
            color: var(--cream)
        }
        /* MEDIOS */
        
        #medios {
            background: var(--dark2);
            position: relative
        }
        
        #medios::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(to right, transparent, var(--crimson-dark), transparent)
        }
        
        .medios-stats-row {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 1px;
            background: rgba(139, 26, 26, .2);
            border: 1px solid rgba(139, 26, 26, .2);
            margin-top: 3rem
        }
        
        .medios-stat-box {
            background: var(--dark2);
            padding: 2.5rem 1.5rem;
            text-align: center
        }
        
        .medios-stat-box .n {
            font-family: var(--serif);
            font-size: 3rem;
            font-weight: 300;
            color: var(--gold-light);
            display: block;
            line-height: 1
        }
        
        .medios-stat-box .l {
            font-size: .55rem;
            font-weight: 600;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: var(--muted);
            margin-top: .5rem;
            display: block
        }
        
        .medios-bottom {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            margin-top: 4rem
        }
        
        .medios-tags {
            display: flex;
            flex-wrap: wrap;
            gap: .7rem
        }
        
        .medio-tag {
            font-size: .6rem;
            font-weight: 500;
            letter-spacing: .1em;
            color: rgba(245, 239, 224, .45);
            padding: .35rem .8rem;
            border: 1px solid rgba(139, 26, 26, .2);
            transition: all .3s
        }
        
        .medio-tag:hover {
            color: var(--white);
            border-color: var(--crimson-light)
        }
        
        .medio-tag.d {
            color: rgba(245, 239, 224, .55);
            border-color: rgba(139, 26, 26, .35)
        }
        
        .medios-nota {
            font-family: var(--serif);
            font-size: 1.1rem;
            color: rgba(245, 239, 224, .65);
            line-height: 1.9;
            margin-bottom: 1.5rem
        }
        /* TRIÁNGULO */
        
        #triangulo {
            background: var(--black)
        }
        
