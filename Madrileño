        }
        
        @media(max-width:768px) {
            .sobre-grid,
            .galardon-grid,
            .revista-grid,
            .gala-content,
            .contacto-grid,
            .medios-bottom {
                grid-template-columns: 1fr;
                gap: 3rem
            }
            .noticias-grid,
            .noticias-sec-row {
                grid-template-columns: 1fr
            }
            .nav-links {
                display: none
            }
            .ganadores-grid {
                grid-template-columns: 1fr
            }
            .ganador-card:first-child {
                grid-column: span 1
            }
            .stats-row,
            .medios-stats-row {
                grid-template-columns: repeat(2, 1fr)
            }
            .modal-box {
                grid-template-columns: 1fr
            }
            .modal-img {
                min-height: 220px
            }
            .footer-inner {
                text-align: center
            }
            .footer-links {
                flex-wrap: wrap;
                justify-content: center
            }
        }
        /* Ticker / marquee logos */
        
        .ticker-wrap {
            overflow: hidden;
            width: 100%;
            margin-top: 3rem;
            padding: 1.5rem 0;
            border-top: 1px solid rgba(139, 26, 26, .15);
            border-bottom: 1px solid rgba(139, 26, 26, .15)
        }
        
        .ticker-track {
            display: flex;
            align-items: center;
            gap: 4rem;
            width: max-content;
            animation: ticker-scroll 35s linear infinite
        }
        
        .ticker-track:hover {
            animation-play-state: paused
        }
        
        .ticker-logo {
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 64px;
            padding: .5rem 1.2rem;
            background: #fff;
