        }
        
        .ticker-logo:hover {
            opacity: 1;
            filter: brightness(1.05);
            transform: scale(1.06)
        }
        
        .ticker-logo img {
            height: 100%;
            width: auto;
            max-width: 140px;
            object-fit: contain;
            display: block
        }
        
        .ticker-logo--white {
            background: #fff;
            border-radius: 6px;
            padding: .5rem 1.2rem
        }
        
        .ticker-logo--large {
            height: 90px
        }
        
        .ticker-logo--vivir img {
            filter: brightness(0.18) contrast(1.2)
        }
        
        @keyframes ticker-scroll {
            0% {
                transform: translateX(0)
            }
            100% {
                transform: translateX(-50%)
            }
        }
    </style>
</head>

